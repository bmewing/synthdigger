# Environment configuration variables for music_embeddings

# Path to the Discogs-EffNet ONNX model weight file
MUSIC_EMBEDDING_MODEL_PATH=./models/discogs-effnet-bsdynamic-1.onnx

# Output directory for saving generated track embeddings and JSON metadata
MUSIC_EMBEDDING_OUTPUT_DIR=./data/embeddings

# Audio sampling rate (MUST be 16000 Hz for the default model)
MUSIC_EMBEDDING_SAMPLE_RATE=16000

# Optional: Maximum audio duration in seconds to load (useful for quick testing/development)
# MUSIC_EMBEDDING_MAX_SECONDS=30.0

# Local catalog database: a single DuckDB file (no server needed). Created automatically.
DUCKDB_PATH=./data/music.duckdb

# Plex Media Server integration (used to sync metadata/play history and to push generated playlists)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your-plex-token-here

# Where THIS machine can reach the Plex server's music files: an SMB share
# (\\nas\media), an NFS mount (/mnt/media), or leave unset when the pipeline
# runs directly on the Plex host (Plex's own reported paths are used then).
# MUSIC_LIBRARY_ROOT=

# Comma-separated names of your top-level music folder(s) as they appear in
# file paths (e.g. "Plex Music,Classical"). Aligns the paths Plex reports with
# the paths recorded at scan time when the two see different mounts.
# PLEX_MUSIC_FOLDERS=
# Stable machineIdentifier of your Plex server (see plex.tv/api/v2/resources with your
# token, or check the "clientIdentifier" field). Only needed for the cloud Functions,
# which use it to pick the right server among your account's resources.
PLEX_SERVER_MACHINE_ID=

# Session cookie signing key for the cloud Functions - generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Must be identical across every deployed Function.
SESSION_SECRET_KEY=

# OpenRouter API (optional: powers AI playlist titles, cover art prompts, freeform
# vibe interpretation - via DeepSeek models routed through OpenRouter - and AI cover
# art generation. One key covers all of it.)
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Set to "true" to hide the vibe input box and AI title/cover buttons and skip all
# AI calls, regardless of whether OPENROUTER_API_KEY is set.
DISABLE_AI_FEATURES=

# Cloudflare R2 object storage (used by `publish` to upload read-path parquet for the cloud app)
# Create an R2 bucket + API token in the Cloudflare dashboard; the endpoint defaults to
# https://<account-id>.r2.cloudflarestorage.com unless R2_ENDPOINT_URL is set explicitly.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=music-discovery
